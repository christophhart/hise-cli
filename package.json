{
  "name": "@hise/cli",
  "version": "0.1.0",
  "description": "Official command-line interface for HISE setup and REPL workflows",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christoph-hart/hise-cli.git"
  },
  "homepage": "https://github.com/christoph-hart/hise-cli#readme",
  "bugs": {
    "url": "https://github.com/christoph-hart/hise-cli/issues"
  },
  "keywords": [
    "hise",
    "audio",
    "cli",
    "repl",
    "setup"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "hise-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:screencasts": "vitest run src/tui/screencast/tape-runner.test.ts",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js"
  },
  "devDependencies": {
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/terminal-link": "^1.1.0",
    "brace-expansion": "^5.0.4",
    "chalk": "^5.4.1",
    "chevrotain": "^12.0.0",
    "cli-table3": "^0.6.5",
    "esbuild": "^0.25.10",
    "fastest-levenshtein": "^1.0.16",
    "ink": "6.8.0",
    "ink-box": "^1.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.4",
    "node-pty": "^1.1.0",
    "picomatch": "^4.0.3",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ink-tools/ink-mouse": "^2.1.0",
    "terminal-link": "^5.0.0"
  }
}
