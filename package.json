{
  "name": "@hise/cli",
  "version": "0.2.0",
  "description": "Official command-line interface for HISE REPL and automation workflows",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/christoph-hart/hise-cli.git"
  },
  "homepage": "https://github.com/christoph-hart/hise-cli#readme",
  "bugs": {
    "url": "https://github.com/christoph-hart/hise-cli/issues"
  },
  "keywords": [
    "hise",
    "audio",
    "cli",
    "repl",
    "automation"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "hise-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live-contract": "vitest run --config vitest.live.config.ts",
    "test:live-contract:inspect": "vitest run --config vitest.live.config.ts src/live-contract/inspect.live.test.ts",
    "test:live-contract:script": "vitest run --config vitest.live.config.ts src/live-contract/script.live.test.ts",
    "test:screencasts": "vitest run --config vitest.screencast.config.ts",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "dev:profile": "npm run build && node dist/index.js --profile",
    "build:binary": "npm run build && node scripts/build-binary.mjs",
    "build:binary:mac": "npm run build && node scripts/build-binary.mjs --target bun-darwin-arm64",
    "build:binary:linux": "npm run build && node scripts/build-binary.mjs --target bun-linux-x64",
    "build:binary:windows": "npm run build && node scripts/build-binary.mjs --target bun-windows-x64"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "chalk": "^5.4.1",
    "chevrotain": "^12.0.0",
    "esbuild": "^0.25.10",
    "fastest-levenshtein": "^1.0.16",
    "ink": "6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-testing-library": "^4.0.0",
    "marked": "15.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@byteland/ink-scroll-bar": "^1.0.0",
    "@ink-tools/ink-mouse": "^2.1.0",
    "cli-highlight": "^2.1.11",
    "highlight.js": "^11.11.1",
    "ink-scroll-view": "^0.3.6",
    "marked-terminal": "^7.3.0",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.8.3"
  }
}
